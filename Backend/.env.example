# Environment: Local / Docker
PORT=3000
APP_ENV=dev

# ============================================================
# Database Configuration for Neon (Development & Production)
# ============================================================
# Update these connection strings with your actual Neon project URLs

# Development Neon Database
# Get this from Neon Console: your-dev-project > Connection String
DATABASE_URL_DEV=postgresql://neondb_owner:YOUR_DEV_PASSWORD@YOUR_DEV_HOST/dapoer_dev?sslmode=require&channel_binding=require

# Production Neon Database  
# Get this from Neon Console: your-prod-project > Connection String
DATABASE_URL_PROD=postgresql://neondb_owner:YOUR_PROD_PASSWORD@YOUR_PROD_HOST/dapoer_production?sslmode=require&channel_binding=require

# Optional override URL (only used if DATABASE_URL_DEV/PROD is not set)
# DB_URL=

# ============================================================
# Migration Configuration
# ============================================================
# Migration table name (automatically created by node-pg-migrate)
# Default: pgmigrations
# No need to modify unless you have specific requirements

# ============================================================
# Node Environment
# ============================================================
# NODE_ENV=production (set automatically in Docker)
# NODE_ENV=development (set for local dev)
